# ---------------------------------------------------------------------------
# LLM provider — "gemini" | "anthropic"
# ---------------------------------------------------------------------------
LLM_PROVIDER=gemini

# Gemini (required when LLM_PROVIDER=gemini)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Anthropic (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key

# ---------------------------------------------------------------------------
# Teams / Agents SDK
# ---------------------------------------------------------------------------
TEAMS_TEAM_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
TEAMS_CHANNEL_ID=19:xxxx@thread.tacv2
MICROSOFT_APP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MICROSOFT_APP_PASSWORD=your-bot-app-password
MICROSOFT_APP_ALLOW_ANONYMOUS=false

# ---------------------------------------------------------------------------
# Microsoft Graph — Excel tracker
# ---------------------------------------------------------------------------
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-client-secret
GRAPH_EXCEL_DRIVE_ID=b!your-drive-id
GRAPH_EXCEL_ITEM_ID=01YOURTRACKERITEMID
GRAPH_EXCEL_SHEET_NAME=Onboarding

# Microsoft Graph — Forms (optional, only needed for form lookup queries)
GRAPH_FORMS_FORM_ID=placeholder

# Microsoft Graph — Staff roster workbooks (one workbook per location)
# Preferred: point to a JSON file like config/staff_rosters.json
STAFF_ROSTER_LOCATIONS_FILE=config/staff_rosters.json

# Optional fallback: inline JSON instead of a file
# Uses GRAPH_EXCEL_DRIVE_ID as the default drive_id when omitted below.
# STAFF_ROSTER_LOCATIONS_JSON={"collier":{"item_id":"COLLIER_WORKBOOK_ITEM_ID"},"miami":{"item_id":"MIAMI_WORKBOOK_ITEM_ID"}}

# ---------------------------------------------------------------------------
# DocuSign (JWT Grant — server-to-server)
# ---------------------------------------------------------------------------
DOCUSIGN_ACCOUNT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
DOCUSIGN_INTEGRATION_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
DOCUSIGN_USER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
DOCUSIGN_PRIVATE_KEY_PATH=./docusign_private.key
DOCUSIGN_TEMPLATE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi
DOCUSIGN_CONNECT_URL=https://your-subdomain.ngrok-free.app

# ---------------------------------------------------------------------------
# Outlook email
# ---------------------------------------------------------------------------
OUTLOOK_SENDER_EMAIL=hr@yourcompany.com

# Email template (optional — defaults shown)
EMAIL_TEMPLATE_PATH=templates/onboarding_email.html
EMAIL_SUBJECT_TEMPLATE=Welcome to the team, $employee_name!
CLEAR_TO_START_CC_EMAILS=hr@yourcompany.com,ops@yourcompany.com
I9_DOCUMENTS_ATTACHMENT_PATH=attachments/List of acceptable I9 documents.pdf

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8080
WEBHOOK_SECRET=change-me-to-a-strong-random-string
