# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Chat interface — "slack" | "teams" (default: teams)
CHAT_INTERFACE=slack

# Azure AD (app registration for Microsoft Graph)
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-client-secret

# Microsoft Graph — Excel tracker
GRAPH_EXCEL_DRIVE_ID=b!...
GRAPH_EXCEL_ITEM_ID=01...
GRAPH_EXCEL_SHEET_NAME=Onboarding

# Microsoft Graph — Forms (not required for curl webhook tests)
GRAPH_FORMS_FORM_ID=placeholder

# ---------------------------------------------------------------------------
# Slack (required when CHAT_INTERFACE=slack)
# ---------------------------------------------------------------------------
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_CHANNEL_ID=C012AB3CD   # HR notification channel

# ---------------------------------------------------------------------------
# Teams (required when CHAT_INTERFACE=teams)
# ---------------------------------------------------------------------------
TEAMS_TEAM_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
TEAMS_CHANNEL_ID=19:xxxx@thread.tacv2

# Azure Bot (Teams bot framework — only needed when CHAT_INTERFACE=teams)
MICROSOFT_APP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MICROSOFT_APP_PASSWORD=your-bot-app-password

# ---------------------------------------------------------------------------
# DocuSign (JWT Grant — server-to-server)
# ---------------------------------------------------------------------------
DOCUSIGN_ACCOUNT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
DOCUSIGN_INTEGRATION_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
DOCUSIGN_USER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
DOCUSIGN_PRIVATE_KEY_PATH=./docusign_private.key
DOCUSIGN_TEMPLATE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8080

# Webhook security (shared secret sent by Power Automate / curl tests)
WEBHOOK_SECRET=change-me-to-a-strong-random-string
