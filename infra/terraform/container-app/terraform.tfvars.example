# Copy this file to `terraform.tfvars` when you are ready to deploy.
# Every uncommented value below should be reviewed and updated.
# Use quotes for all string values, even IDs and secrets.

# Existing shared Azure resource group that already contains your ACR,
# Cosmos account, and Storage account.
resource_group_name = "REPLACE_ME_EXISTING_RESOURCE_GROUP"

# Existing Azure Container Registry name in the resource group above.
container_registry_name = "REPLACE_ME_EXISTING_ACR_NAME"

# Existing Azure Container Registry admin credentials.
# Container Apps needs explicit registry auth for this private image pull setup.
# In the Azure Portal, enable "Admin user" on the ACR if it is not already enabled,
# then copy the username and one of the passwords here.
container_registry_username = "REPLACE_ME_ACR_ADMIN_USERNAME"
container_registry_password = "REPLACE_ME_ACR_ADMIN_PASSWORD"

# New Container Apps environment name for this app.
# Update this if you want a different logical environment name.
container_app_environment_name = "onboarding-agent-env"

# New Container App name for this app.
container_app_name = "onboarding-agent"

# Existing Azure Storage Account name used for Azure Queue.
storage_account_name = "REPLACE_ME_EXISTING_STORAGE_ACCOUNT"

# Existing Cosmos DB account name.
existing_cosmos_account_name = "REPLACE_ME_EXISTING_COSMOS_ACCOUNT"

# LLM provider configuration.
# Use "gemini" unless you explicitly want Anthropic.
llm_provider = "gemini"
gemini_model = "gemini-2.5-flash"

# Image tag to deploy. Use an immutable tag, not `latest`, for real deploys.
# Example: "2026-03-29-1" or a git SHA.
image_tag = "REPLACE_ME_IMAGE_TAG"

# Container sizing.
# 0.5 CPU / 1Gi is a reasonable low-cost starting point.
min_replicas = 1
max_replicas = 3
cpu          = 0.5
memory       = "1Gi"

# Azure AD / Graph application settings.
# These should match the app registration/service principal used by the agent.
azure_tenant_id     = "REPLACE_ME_AZURE_TENANT_ID"
azure_client_id     = "REPLACE_ME_GRAPH_CLIENT_ID"
azure_client_secret = "REPLACE_ME_GRAPH_CLIENT_SECRET"

# Teams bot settings.
# `microsoft_app_id` is the bot/app registration client ID.
# `teams_channel_id` is the target channel for proactive notifications.
microsoft_app_id       = "REPLACE_ME_TEAMS_APP_ID"
microsoft_app_password = "REPLACE_ME_TEAMS_APP_PASSWORD"
teams_channel_id       = "REPLACE_ME_TEAMS_CHANNEL_ID"

# Graph Excel tracker settings.
graph_excel_drive_id = "REPLACE_ME_GRAPH_EXCEL_DRIVE_ID"
graph_excel_item_id  = "REPLACE_ME_GRAPH_EXCEL_ITEM_ID"

# DocuSign settings.
# Paste the private key directly between the heredoc markers below.
docusign_account_id      = "REPLACE_ME_DOCUSIGN_ACCOUNT_ID"
docusign_integration_key = "REPLACE_ME_DOCUSIGN_INTEGRATION_KEY"
docusign_user_id         = "REPLACE_ME_DOCUSIGN_USER_ID"
docusign_private_key = <<-EOT
-----BEGIN RSA PRIVATE KEY-----
REPLACE_ME_WITH_YOUR_ACTUAL_DOCUSIGN_PRIVATE_KEY_CONTENT
-----END RSA PRIVATE KEY-----
EOT
docusign_template_id     = "REPLACE_ME_DOCUSIGN_TEMPLATE_ID"

# Base hosted URL that DocuSign should call back into for envelope status events.
# Set this to your Container App base URL after first apply, then re-apply.
# Example: "https://onboarding-agent.<region>.azurecontainerapps.io"
docusign_connect_url = "REPLACE_ME_CONTAINER_APP_BASE_URL"

# LLM provider secrets.
# For Gemini, set `gemini_api_key` and leave `anthropic_api_key` empty.
# For Anthropic, do the reverse and set `llm_provider = "anthropic"`.
gemini_api_key    = "REPLACE_ME_GEMINI_API_KEY"
anthropic_api_key = ""

# Shared-secret used by inbound webhook callers.
webhook_secret = "REPLACE_ME_WEBHOOK_SECRET"

# Existing Cosmos DB account key.
# This gives the app runtime access to the reused Cosmos account.
cosmos_key = "REPLACE_ME_COSMOS_KEY"

# New Cosmos SQL database and container names for a fresh app slate.
# These can reuse the defaults if you deleted the old app-specific resources.
state_store_backend                   = "cosmos"
cosmos_database_name                 = "onboarding-agent"
cosmos_state_container_name          = "state-records"
graph_checkpoint_cosmos_container_name = "langgraph-checkpoints"

# Existing Storage Account connection string.
# This gives the app runtime access to the reused Azure Queue account.
storage_account_connection_string = "REPLACE_ME_STORAGE_ACCOUNT_CONNECTION_STRING"

# New queue name for the app inside the existing Storage account.
azure_storage_queue_name = "onboarding-jobs"

# LangGraph checkpoint backend.
# Leave as "cosmos" for hosted deployment.
graph_checkpoint_backend = "cosmos"

# Optional Outlook sender email used by some email flows.
# outlook_sender_email = "hr@example.com"

# Optional but recommended when roster workbook IDs are sensitive.
# Keep `config/staff_rosters.json` ignored locally, then populate this value with:
#   scripts/sync_staff_rosters_to_tfvars.sh infra/terraform/container-app/terraform.tfvars
# Example:
# staff_roster_locations_json = "{\"collier\":{\"drive_id\":\"...\",\"item_id\":\"...\",\"roster_sheet_name\":\"Roster_Data\",\"capacity_sheet_name\":\"Capacity\"}}"
# staff_roster_locations_json = "{}"

# Optional custom tags for resources Terraform creates.
# tags = {
#   owner = "matthew"
#   app   = "onboarding-agent"
# }
